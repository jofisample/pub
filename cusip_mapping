import os
import re
import datetime as dt
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
import matplotlib.ticker as ticker
from pandas.tseries.offsets import BDay
from mpl_toolkits.axes_grid1 import make_axes_locatable
from utils.qis_plot import qis_plot as qp

# Centralized configuration variables
right_box_ratio = 0.2
max_width_characters = 20
font_size = 8
plot_width = 10
plot_height = 5

def auto_wrap_text(text, max_line_length=max_width_characters):
    """Auto insert line breaks (\n) into text so that no line exceeds max_line_length chars."""
    words = text.split(' ')
    lines = []
    current_line = []
    current_length = 0
    for word in words:
        if current_length + len(word) + 1 <= max_line_length:  # +1 for space
            current_line.append(word)
            current_length += len(word) + 1
        else:
            lines.append(' '.join(current_line))
            current_line = [word]
            current_length = len(word) + 1
    if current_line:
        lines.append(' '.join(current_line))
    return '\n'.join(lines)


def load_data(raw_data_path, mappings_path):
    """Load and prepare raw data for processing."""
    raw = pd.read_excel(raw_data_path)
    raw["EOMD"] = pd.to_datetime(raw["EOMD"])

    today = dt.datetime.today()
    one_month_back = today - pd.DateOffset(months=1)
    end_of_last_month = one_month_back.replace(day=1) + pd.DateOffset(months=1) - pd.DateOffset(days=1)
    end_of_same_month_last_year = end_of_last_month - pd.DateOffset(years=1) - BDay(1)

    raw = raw[(raw["EOMD"].dt.date >= end_of_same_month_last_year.date()) &
              (raw["EOMD"].dt.date <= end_of_last_month.date())]
    raw.set_index("EOMD", inplace=True)

    mappingsxlsx = pd.read_excel(mappings_path, sheet_name="Factor Code")
    mappings = pd.Series(mappingsxlsx["Short_Name"].values, index=mappingsxlsx["FACTOR"]).to_dict()
    
    return raw, mappings


def plot_data_for_region(raw, mappings, region, lst, comments, output_path):
    """Plot data for a specific region."""
    cols = [f"{region}_{i}" for i in lst]
    
    # Filter and process data for the selected region
    df = raw[cols].copy()
    df.iloc[0] = 0
    df = (1 + df.fillna(0)).cumprod() * 100
    df.columns = [re.sub(r"[A-Z]+_(.*?)_0_USD_E_3", r"\1", col) for col in df.columns]
    
    valid_elements = df.columns.tolist()

    # Create plot
    fig, ax1 = plt.subplots(figsize=(plot_width, plot_height))
    qp.plot(df.rename(columns=mappings), ax=ax1)

    ax1.legend(loc='upper left', frameon=True)
    lines = ax1.get_lines()
    color_cycle = ax1._get_lines.prop_cycler
    colors = [next(color_cycle)["color"] for _ in range(df.shape[1])]
    
    series_names = df.columns.tolist()
    dic = dict(zip(series_names, colors))
    
    # Add comments
    divider = make_axes_locatable(ax1)
    ax2 = divider.append_axes("right", size=f"{right_box_ratio * 100}%", pad=0.1)
    ax2.axis("off")

    legend_handles = []
    legend_labels = []

    for series_name, comment in comments:
        assert series_name in valid_elements, f"{series_name} is not a valid factor"
        line_handle = plt.Line2D([0], [0], color=dic[series_name], lw=2)
        legend_handles.append(line_handle)
        wrapped_comment = auto_wrap_text(comment)
        legend_labels.append(wrapped_comment)

    ax2.legend(legend_handles, legend_labels, loc='upper left', frameon=False, prop={"size": font_size})

    # Format date on the x-axis
    date_format = mdates.DateFormatter("%b-%y")
    ax1.xaxis.set_major_formatter(date_format)
    ax1.xaxis.set_major_locator(mdates.MonthLocator())
    ax1.xaxis.set_minor_locator(ticker.NullLocator())

    tick_positions = np.linspace(df.index.min().value, df.index.max().value, 13)
    tick_positions = pd.to_datetime(tick_positions)
    tick_labels = [(d + pd.DateOffset(months=1)).strftime("%b-%y") for d in tick_positions]
    tick_labels[-1] = ""

    shade_start = tick_positions[-2]
    shade_end = tick_positions[-1]

    ax1.axvspan(shade_start, shade_end, facecolor="gray", alpha=0.3, edgecolor="none")
    ax1.set_xticks(tick_positions)
    ax1.set_xticklabels(tick_labels)
    ax1.tick_params(axis="x", labelsize=9)
    ax1.tick_params(axis="y", labelsize=9)

    plt.tight_layout()

    # Save the figure
    today = dt.datetime.today().strftime("%Y%m%d")
    figname = f"factorperformance_{region}_{today}.png"
    plt.savefig(os.path.join(output_path, "plots", figname), dpi=600)
    plt.close(fig)


def process_all_regions(regions, raw_data_path, mappings_path, output_path, lst, comments):
    """Process and plot data for all regions."""
    raw, mappings = load_data(raw_data_path, mappings_path)
    
    for region in regions:
        plot_data_for_region(raw, mappings, region, lst, comments, output_path)


