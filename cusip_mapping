def get_last_month_performance(df):
    """
    Calculate the percentage change for each factor in the last month.
    
    Parameters:
    - df: A pandas DataFrame with date-indexed data.
    
    Returns:
    - A dictionary with factor names as keys and their performance as values.
    """
    last_month_end = df.index.max()  # Last date in the dataframe
    last_month_start = last_month_end - pd.DateOffset(months=1)
    
    # Find the start and end of the last fully passed month
    start_value = df[df.index >= last_month_start].iloc[0]
    end_value = df[df.index == last_month_end].iloc[0]

    # Calculate percentage performance
    performance_dict = ((end_value - start_value) / start_value * 100).to_dict()

    return performance_dict


def generate_comments_from_performance(performance_dict):
    """
    Generate a list of comments based on the performance of each factor.
    
    Parameters:
    - performance_dict: A dictionary with factor names and their percentage performance.
    
    Returns:
    - A list of tuples containing factor name and a comment on whether it went up or down.
    """
    comments = []
    for factor, performance in performance_dict.items():
        if performance > 0:
            comment = f"Up {performance:.2f}%"
        else:
            comment = f"Down {abs(performance):.2f}%"
        comments.append((factor, comment))
    
    return comments


def process_all_regions(regions, raw_data_path, mappings_path, output_path, lst):
    """Process and plot data for all regions."""
    raw, mappings = load_data(raw_data_path, mappings_path)
    
    for region in regions:
        # Filter the relevant data for the region
        cols = [f"{region}_{i}" for i in lst]
        df_region = raw[cols].copy()
        df_region.iloc[0] = 0
        df_region = (1 + df_region.fillna(0)).cumprod() * 100
        df_region.columns = [re.sub(r"[A-Z]+_(.*?)_0_USD_E_3", r"\1", col) for col in df_region.columns]

        # Get the last month's performance
        performance_dict = get_last_month_performance(df_region)

        # Generate comments based on performance
        comments = generate_comments_from_performance(performance_dict)

        # Plot the data with generated comments
        plot_data_for_region(raw, mappings, region, lst, comments, output_path)


