def main():
    # Define constants and parameters
    fac_lst = ['PMOM1', 'PMOM3', 'PMOM9', 'PMOM12', 'PMOM1_9', 'PMOM1_12', 'NREV2', 'UPDWNREV',
               'SLREV2_IB', 'SUPDWNREV', 'EPF', 'FCFP', 'OACFP', 'EBITDEV', 'BP', 'SP', 'EP',
               'NORMEP', 'ROE', 'ROIC', 'NM', 'EBITDAM', 'LTGRO', 'NIGRO1', 'SGRO1', 'PEG',
               'STGRO_IB', 'DEBTE', 'YLDASS', 'PAYOUT', 'DP', 'BB_YIELD2', 'AT', 'INVS',
               'ACCXASS1', 'ACCXASS2', 'C2SALES', 'C2DEP', 'RDCAP', 'FLCAPD', 'CAPD',
               'TOT_YLD2', 'TAXPDPT', 'UPDWNREV3', 'SUPDWNREV3', 'VOL', 'EMOM3', 'IGRO',
               'NIGRVOL', 'GPOA', 'AG', 'RESMOM1_12', 'ROA', 'CEMP_NUM', 'CV', 'CG', 'CM', 'CQ']
    sdate_ret = '1989-12-29'
    edate_ret = '2024-08-06'
    edate_ret = pd.to_datetime(edate_ret)
    rawpath = 'path_to_your_data'  # Update this with your actual data path
    
    # Prepare total returns DataFrame
    # Replace with actual data loading
    totret_df = pd.read_csv('totret_data.csv')  # Replace with your actual data file
    totret_df = prepare_totret_df(totret_df)
    
    # Dictionary to store results
    results_dict = {}
    
    # Loop over regions and neutralization settings
    for region_txt in ['US', 'EU', 'JP']:
        region_results = {}
        for ntrl in [0, 1]:
            # Read factor data
            filter_df = read_factor_data(region_txt, ntrl, rawpath)
            # Prepare ISIN DataFrame
            isin_df = prepare_isin_df(filter_df, sdate_ret, edate_ret)
            # Prepare filtered returns DataFrame
            ret_fil_df = prepare_ret_fil_df(totret_df, filter_df, sdate_ret, edate_ret)
            # Adjust returns DataFrame to align with ISIN DataFrame
            ret_fil_df = adjust_ret_fil_df(isin_df, ret_fil_df)
            # Ensure 'DATE' and 'FS_ID' are in filter_df
            filter_df = filter_df.copy()
            # Determine neutralization setting and compute factor indices
            if ntrl == 0:
                # No neutralization
                indx_df = cal_factor_indx(filter_df, ret_fil_df, sdate_ret, edate_ret, fac_lst)
                region_results[f'Factor return - {region_txt}'] = indx_df
    
                # Long-only portfolio
                indx_df_long = cal_factor_indx(filter_df, ret_fil_df, sdate_ret, edate_ret, fac_lst, legs=[1, 0])
                region_results[f'Factor return - {region_txt} - L'] = indx_df_long
            else:
                # Sector neutralization
                indx_df_sector = cal_factor_indx(filter_df, ret_fil_df, sdate_ret, edate_ret, fac_lst, ntrl='SECTOR')
                region_results[f'Factor return - sector ntrl - {region_txt}'] = indx_df_sector
    
        # Store results for the region
        results_dict[region_txt] = region_results
    
    # The results_dict now contains all the indices without writing to CSV files
    # You can access them like:
    # results_dict['US']['Factor return - US']
    
    # For demonstration, let's print the keys of the results
    for region, res in results_dict.items():
        print(f"Results for {region}:")
        for key in res:
            print(f"  {key}")

