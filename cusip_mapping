# Assuming opp_lst and rnk_opp_lst are already defined
rnk_opp_lst = ['RANK_' + fac for fac in opp_lst]

# Create a set for faster lookup
rnk_opp_set = set(rnk_opp_lst)

# Avoid setting MultiIndex by keeping 'DATE' and 'FS_ID' as columns
# Ensure 'DATE' and 'FS_ID' are present in filter_df
if 'DATE' not in filter_df.columns or 'FS_ID' not in filter_df.columns:
    raise ValueError("filter_df must contain 'DATE' and 'FS_ID' columns.")

# Calculate CV, CG, CM
for comp_name, factors in comp_dct.items():
    # List of 'RANK_' columns for the composite factor
    col_lst = ['RANK_' + fac for fac in factors]
    # Ensure all required columns are present
    required_cols = ['DATE', 'FS_ID'] + col_lst
    sub_df = filter_df[required_cols].copy()
    # Drop rows with missing values in any of the constituent factors
    sub_df = sub_df.dropna(subset=col_lst)
    # Adjust ranks and compute percentile ranks for each factor
    for col in col_lst:
        if col in rnk_opp_set:
            # Adjust ranks for opposite factors by multiplying by -1
            sub_df[col] = -sub_df[col]
            # Re-rank the adjusted ranks within each date
            sub_df[col] = sub_df.groupby('DATE')[col].transform(lambda x: x.rank(method='min', ascending=True))
        # Convert ranks to percentile ranks within each date
        sub_df[col] = sub_df.groupby('DATE')[col].transform(lambda x: x.rank(method='min') / (x.count() + 1))
    # Calculate the composite score as the mean of percentile ranks
    sub_df[comp_name] = sub_df[col_lst].mean(axis=1)
    # Merge the composite score back into filter_df
    filter_df = filter_df.merge(sub_df[['DATE', 'FS_ID', comp_name]], on=['DATE', 'FS_ID'], how='left')
