def calculate_efficacy(filter_df, totret_df, sdate_ret, edate_ret, factors):
    """
    Calculates efficacy using the provided filter_df and totret_df over the specified date range.

    Parameters:
    - filter_df (pd.DataFrame): The factor DataFrame with 'DATE', 'FS_ID', etc.
    - totret_df (pd.DataFrame): The total returns DataFrame with dates as index and FS_IDs as columns.
    - sdate_ret (str): Start date for returns.
    - edate_ret (str or datetime): End date for returns.
    - factors (list): List of factors to process.

    Returns:
    - indx_df: DataFrame of factor indices using daily returns.
    - indxM_df: DataFrame of factor indices using monthly returns.
    """

    edate_ret = pd.to_datetime(edate_ret)

    # Prepare ISIN DataFrame
    isin_df = prepare_isin_df(filter_df, sdate_ret, edate_ret)

    # Prepare filtered returns DataFrame
    ret_fil_df = prepare_ret_fil_df(totret_df, filter_df, sdate_ret, edate_ret)

    # Adjust returns DataFrame to align with ISIN DataFrame and clip extreme values
    ret_fil_df = adjust_ret_fil_df(isin_df, ret_fil_df)

    # Calculate cumulative returns for daily returns
    cum_returns = ret_fil_df.add(1).cumprod(axis=0)

    # Resample cumulative returns to business month-end frequency for monthly returns
    cum_returns_monthly = cum_returns.resample('BM').last()

    # Calculate monthly returns
    retM_fil_df = cum_returns_monthly.pct_change().fillna(0)

    # Adjust date ranges if necessary
    sdate_ret = pd.to_datetime(sdate_ret)
    edate_ret = pd.to_datetime(edate_ret)

    # Ensure returns DataFrames are within the specified date range
    ret_fil_df = ret_fil_df[(ret_fil_df.index >= sdate_ret) & (ret_fil_df.index <= edate_ret)]
    retM_fil_df = retM_fil_df[(retM_fil_df.index >= sdate_ret) & (retM_fil_df.index <= edate_ret)]

    # Calculate factor indices using daily returns
    indx_df = cal_factor_indx(filter_df, ret_fil_df, sdate_ret, edate_ret, factors)

    # Calculate factor indices using monthly returns
    # Adjust rebalancing months to include all months for monthly data
    indxM_df = cal_factor_indx(filter_df, retM_fil_df, sdate_ret, edate_ret, factors, rebalmth=list(range(1, 13)))

    return indx_df, indxM_df


