def rebal_factors(filter_df, rebalfreq, fac_lst):
    """
    Adjusts the factor DataFrame for rebalancing frequencies and merges quintile information.

    Parameters:
    - filter_df (pd.DataFrame): The DataFrame with factor data.
    - rebalfreq (int): Rebalancing frequency (1 for monthly, 3 for quarterly).
    - fac_lst (list): List of factors to process.

    Returns:
    - pd.DataFrame: DataFrame adjusted for rebalancing with updated quintile information.
    """
    fac_qtl_lst = ['QTILE_' + fac for fac in fac_lst]

    filter_rebal_df = filter_df.copy()

    # Compute 'REBAL' dates based on rebalancing frequency
    if rebalfreq == 3:
        filter_rebal_df['REBAL'] = filter_rebal_df['DATE'] + pd.offsets.BQuarterEnd(0)
    elif rebalfreq == 1:
        filter_rebal_df['REBAL'] = filter_rebal_df['DATE'] + pd.offsets.BMonthEnd(0)
    else:
        raise ValueError("Invalid rebalancing frequency. Use 1 for monthly or 3 for quarterly.")

    # Drop duplicates to keep the last quintile information for each 'REBAL' and 'FS_ID'
    filter_qtile_df = filter_rebal_df.drop_duplicates(subset=['REBAL', 'FS_ID'], keep='last')

    # Recompute 'REBAL' date with different offset
    if rebalfreq == 3:
        filter_rebal_df['REBAL'] = filter_rebal_df['DATE'] + pd.offsets.BQuarterEnd(-1)
    elif rebalfreq == 1:
        filter_rebal_df['REBAL'] = filter_rebal_df['DATE'] + pd.offsets.BMonthEnd(-1)

    # Prepare DataFrame for merging
    filter_qtile_df_sub = filter_qtile_df[['REBAL', 'FS_ID'] + fac_qtl_lst]

    # Merge quintile information back into the main DataFrame
    filter_rebal_df = filter_rebal_df.drop(columns=fac_qtl_lst).merge(
        filter_qtile_df_sub, on=['REBAL', 'FS_ID'], how='left', suffixes=('_x', '')
    )

    # Sort by 'FS_ID' and 'DATE' for consistency
    filter_rebal_df = filter_rebal_df.sort_values(by=['FS_ID', 'DATE'])

    return filter_rebal_df


def cal_factor_val(filter_rebal_df, valqtl_lst, fac_lst, impute=True):
    """
    Calculates valuation levels for specified factors and valuation metrics.

    Parameters:
    - filter_rebal_df (pd.DataFrame): The rebalanced factor DataFrame.
    - valqtl_lst (list): List of valuation metrics or combinations thereof.
    - fac_lst (list): List of factors to process.
    - impute (bool): Whether to impute missing values for blended valuations.

    Returns:
    - pd.DataFrame: DataFrame containing valuation levels for each factor and valuation metric.
    """
    # Set specified columns to NaN for financial and real estate sectors
    cols_to_nan = ['FCFP', 'OACFP', 'EBITDEV', 'SP']
    filter_rebal_df.loc[filter_rebal_df['SECTOR'].isin([40, 60]), cols_to_nan] = np.nan

    val_dct = {}

    for valqtl in valqtl_lst:
        # Handle single and multiple valuation metrics
        if isinstance(valqtl, str):
            valqtl_txt = valqtl
            valqtl = [valqtl]
        else:
            valqtl_txt = '+'.join(valqtl)
        val_dct[valqtl_txt] = {}

        filter_rebal_adj_df = filter_rebal_df.copy()

        # Impute missing values for blended valuations
        if impute and len(valqtl) > 1:
            # Calculate median values per date
            mktmed_df = filter_rebal_adj_df.groupby('DATE')[cols_to_nan].median().reset_index()
            # Merge median values back into the DataFrame
            filter_rebal_adj_df = filter_rebal_adj_df.merge(mktmed_df, on='DATE', suffixes=('', '_MKTMED'))
            # Fill NaNs with median values
            for col in cols_to_nan:
                filter_rebal_adj_df[col] = filter_rebal_adj_df[col].fillna(filter_rebal_adj_df[col + '_MKTMED'])
            # Drop the median columns
            filter_rebal_adj_df.drop(columns=[col + '_MKTMED' for col in cols_to_nan], inplace=True)

        for fac in fac_lst:
            val_cal_dct = {}
            qt_col = 'QTILE_' + fac
            # Ensure quintile columns are of integer type
            filter_rebal_adj_df[qt_col] = filter_rebal_adj_df[qt_col].astype(int)
            for val_metric in valqtl:
                # Create a pivot table with median values per quintile and date
                val_df = filter_rebal_adj_df.pivot_table(
                    index='DATE', columns=qt_col, values=val_metric, aggfunc='median'
                )
                # Ensure quintile columns 1 and 5 exist
                if 1 not in val_df.columns:
                    val_df[1] = np.nan
                if 5 not in val_df.columns:
                    val_df[5] = np.nan
                # Replace missing top quintile values with lower quintiles
                val_df[1] = val_df[1].fillna(val_df.get(2)).fillna(val_df.get(3))
                # Replace missing bottom quintile values with higher quintiles
                val_df[5] = val_df[5].fillna(val_df.get(4)).fillna(val_df.get(3))
                # Calculate the valuation ratio
                val_cal_dct[val_metric] = val_df[1].div(val_df[5])
            # Compute mean across valuation metrics
            val_dct[valqtl_txt][fac] = pd.DataFrame(val_cal_dct).mean(axis=1)

    # Convert the valuation dictionary to a DataFrame
    val2_dct = {(k1, k2): v2 for k1, v1 in val_dct.items() for k2, v2 in v1.items()}
    val_df = pd.DataFrame(val2_dct)
    val_df.columns.names = ['VALFAC', 'FACTOR']
    val_df = val_df.swaplevel(axis=1)

    return val_df


