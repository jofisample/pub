import matplotlib.pyplot as plt
import pandas as pd
import numpy as np
from mpl_toolkits.axes_grid1 import make_axes_locatable

# Generate example data with descriptive column names
dates = pd.date_range('2023-01-01', periods=100)
df = pd.DataFrame(np.random.randn(100, 5), index=dates, columns=['Comp Growth', 'Price Momentum', 'Growth Factor', 'Value', 'Quality'])

# Create figure with one main plot
fig, ax1 = plt.subplots(figsize=(10, 5))

# Plot the whole DataFrame in one go on the left subplot (ax1)
df.plot(ax=ax1)

# Move the original legend to the top left
ax1.legend(loc='upper left', frameon=True)

# Retrieve the color cycle from the axes (to get the colors for each line)
lines = ax1.get_lines()  # Get the lines from the first plot
colors = [line.get_color() for line in lines]  # Extract the color used for each time series

# Define the comments for each series
comments = [
    ("Comp Growth", "went up. The others were muted."),
    ("Value", "went down.")
]

# Create a divider for an additional space to the right of the plot
divider = make_axes_locatable(ax1)
ax2 = divider.append_axes("right", size="30%", pad=0.1)
ax2.axis("off")  # Hide the axis for the legend text box

# Create a list of legend handles and labels based on the comments
legend_handles = []
legend_labels = []

for i, (series_name, comment) in enumerate(comments):
    # Find the corresponding line color
    color = colors[i]
    
    # Create a dummy line handle to use in the legend (just a colored line with no data)
    line_handle = plt.Line2D([0], [0], color=color, lw=2)
    legend_handles.append(line_handle)
    
    # Format the label with series name and comment without showing it as a tuple
    legend_label = f"{series_name}: {comment}"
    legend_labels.append(legend_label)

# Use the legend to create the text box with color and comments
ax2.legend(legend_handles, legend_labels, loc='upper left', frameon=False)

# Adjust layout to prevent shrinking of the main plot
plt.subplots_adjust(left=0.1, right=0.9, wspace=0.4)

# Show the plot
plt.show()
